<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="jpa_sesion04_pu" transaction-type="RESOURCE_LOCAL">
        <!-- Proveedor de JPA de Hibernate -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entidades registradas -->
        <class>com.jpa_sesion04.model.Tipo</class>
        <class>com.jpa_sesion04.model.Usuario</class>
        <class>com.jpa_sesion04.model.Categoria</class>
        <class>com.jpa_sesion04.model.Proveedor</class>
        <class>com.jpa_sesion04.model.Producto</class>

        <properties>
            <!-- Propiedades de conexión a MySQL -->
            <property name="jakarta.persistence.jdbc.driver"   value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:mysql://localhost:3306/ciberfarmaweb?useSSL=false&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user"     value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="admin"/>

            <!-- Configuración específica de Hibernate -->
            <property name="hibernate.dialect"     value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql"    value="true"/>
            <property name="hibernate.format_sql"  value="true"/>

            <!-- none: no modifica las tablas (ya existen en BD) -->
            <property name="hibernate.hbm2ddl.auto" value="none"/>
        </properties>
    </persistence-unit>

</persistence>
